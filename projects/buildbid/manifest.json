{
  "project": "buildbid",
  "title": "BuildBid",
  "priority": 1,
  "objective": "Improve estimate reliability and reduce embarrassing misses.",
  "primary_metric": "estimate_accuracy_delta",
  "guardrails": [
    "missing_scope_rate",
    "dependency_error_rate",
    "duplicate_item_rate",
    "hallucinated_line_items",
    "time_to_first_usable_estimate",
    "human_edit_distance"
  ],
  "evaluation_window": "historical replay batch 01",
  "promotion_ladder": ["replay", "shadow", "canary", "production"],
  "mutation_targets": [
    "trade_dependency_rules",
    "scope_gap_detection_rules",
    "confidence_ranking_in_synthesis"
  ],
  "evidence_sources": [
    "historical bid packages",
    "reviewed targets",
    "operator edit logs"
  ],
  "approval_mode": "no autonomous promotion beyond replay without explicit review artifact",
  "rollback_rule": "revert if estimate accuracy does not improve or any guardrail regresses materially"
}
