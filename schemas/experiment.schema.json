{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://arugula.local/schemas/experiment.schema.json",
  "title": "ARUGULA Experiment",
  "type": "object",
  "required": [
    "experiment_id",
    "project",
    "title",
    "mutation_target",
    "primary_metric",
    "guardrails",
    "evaluation_window",
    "promotion_mode"
  ],
  "properties": {
    "experiment_id": { "type": "string" },
    "project": { "type": "string" },
    "title": { "type": "string" },
    "mutation_target": { "type": "string" },
    "primary_metric": { "type": "string" },
    "guardrails": {
      "type": "array",
      "items": { "type": "string" }
    },
    "evaluation_window": { "type": "string" },
    "promotion_mode": {
      "type": "string",
      "enum": ["replay", "shadow", "canary", "production"]
    },
    "rollback_rule": { "type": "string" },
    "notes": { "type": "string" }
  }
}
