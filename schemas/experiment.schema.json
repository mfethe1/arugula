{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://arugula.local/schemas/experiment.schema.json",
  "title": "ARUGULA Experiment",
  "type": "object",
  "required": [
    "experiment_id",
    "project",
    "title",
    "mutation_target",
    "primary_metric",
    "guardrails",
    "evaluation_window",
    "promotion_mode",
    "rollback_rule",
    "approval_policy",
    "tenant_scope"
  ],
  "properties": {
    "experiment_id": { "type": "string" },
    "project": { "type": "string" },
    "title": { "type": "string" },
    "mutation_target": { "type": "string" },
    "primary_metric": { "type": "string" },
    "guardrails": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "evaluation_window": { "type": "string" },
    "promotion_mode": {
      "type": "string",
      "enum": ["replay", "shadow", "canary", "production"]
    },
    "rollback_rule": { "type": "string" },
    "approval_policy": {
      "type": "object",
      "required": ["required", "approvers"],
      "properties": {
        "required": { "type": "boolean" },
        "approvers": {
          "type": "array",
          "items": { "type": "string" }
        },
        "notes": { "type": "string" }
      },
      "additionalProperties": false
    },
    "tenant_scope": {
      "type": "string",
      "enum": ["single-tenant", "shared-control-plane", "not-applicable"]
    },
    "secret_inputs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "notes": { "type": "string" }
  },
  "additionalProperties": false
}
